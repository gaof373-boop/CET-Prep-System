# Streamlit secrets — example template.
#
# USAGE
# -----
# 1. Local dev:  cp secrets.toml.example secrets.toml  (this file
#    is git-ignored), then fill in your real key.  ``streamlit run
#    web_app.py`` will read it automatically.
#
# 2. Cloud deploy (share.streamlit.io):  copy ONLY the lines below
#    into the dashboard's "Settings → Secrets" editor.  Do NOT
#    commit a real secrets.toml to the repo.
#
# Each key here is read by AIService._load_config() in this order:
#   1. st.secrets (this file or cloud dashboard)
#   2. environment variables
#   3. config.json on disk (legacy)

# REQUIRED — your OpenAI / DeepSeek / Anthropic / MiniMax / etc key.
# If you proxy through a different provider, the BASE_URL below
# controls which API the key is sent to.
OPENAI_API_KEY = "sk-REPLACE-ME-WITH-YOUR-KEY"

# OPTIONAL — defaults to https://api.openai.com/v1 if omitted.
# Examples for popular Chinese-friendly providers:
#   DeepSeek :  https://api.deepseek.com/v1
#   MiniMax  :  https://platform.minimaxi.com/v1
#   Qwen     :  https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL = "https://api.deepseek.com/v1"

# OPTIONAL — model name. Defaults to gpt-3.5-turbo.
# Popular choices: deepseek-chat, gpt-4o-mini, claude-3-5-sonnet, etc.
OPENAI_MODEL = "deepseek-chat"
