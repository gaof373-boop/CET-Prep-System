# Build artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.egg-info/
build/
dist/
.cache/

# PyInstaller
*.spec
# buildozer.spec 必须纳入版本控制（CI 端会 sed 它）
!buildozer.spec

# Buildozer / p4a
.buildozer/
bin/
.gradle/

# Logs
logs/
*.log

# Python
*.pyc
__pycache__/
*.egg
*.egg-info/
.eggs/
pip-log.txt

# Virtual envs
venv/
.venv/
env/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Test artifacts
.pytest_cache/
.coverage
htmlcov/

# Buildozer intermediate patches
.p4a_patches/
patch_*.py
stub_*.py
fakecgi/

# Local-only WSL artifacts (not needed in CI)
buildozer.spec.backup

# -------------------------------------------------------------------
# Streamlit Cloud deploy — keep secrets & generated DB off git
# -------------------------------------------------------------------
# Real secrets.toml must NEVER be committed. The .example file is
# committed as a template only.
.streamlit/secrets.toml

# Local config.json may carry the developer's personal API key. The
# AIService falls back to st.secrets first, so this file is optional
# in dev. The web_app's API panel writes to it for local testing.
config.json

# Local SQLite DB can be regenerated by `python -m core.db_init` on
# first run, so we don't ship the 12MB blob with the source.
# Keep it tracked? Comment out the next line if you want it on git.
# (Project currently tracks it for offline dev convenience.)
# database/cet_exam.db
